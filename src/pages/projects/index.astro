---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const statusLabel: Record<string, string> = {
	active: 'Ativo',
	wip: 'Em desenvolvimento',
	archived: 'Arquivado',
};
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead
			title="Projetos — Lucas Lima"
			description="Projetos que construí, contribuí ou estou desenvolvendo."
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>Projetos</h1>
			<p class="subtitle">Projetos que construí, contribuí ou estou desenvolvendo.</p>

			<hr />

			{
				projects.length === 0 ? (
					<p class="empty">Nenhum projeto ainda. Em breve.</p>
				) : (
					<ul class="project-list">
						{projects.map((project) => (
							<li class="project-item">
								<a href={`/projects/${project.id}/`} class="project-link">
									{project.data.coverImage && (
										<div class="cover-wrap">
											<Image
												src={project.data.coverImage}
												alt={project.data.title}
												width={680}
												height={360}
												class="cover-img"
											/>
										</div>
									)}
									<div class="project-info">
										<div class="project-row">
											<span class="project-title">{project.data.title}</span>
											<span class={`status status-${project.data.status}`}>
												{statusLabel[project.data.status]}
											</span>
										</div>
										<p class="project-desc">{project.data.description}</p>
										<div class="tech-list">
											{project.data.tech.map((t) => (
												<span class="tech">{t}</span>
											))}
										</div>
									</div>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		font-size: 2rem;
		letter-spacing: -0.03em;
		margin-bottom: 0.5rem;
	}
	.subtitle {
		color: var(--muted);
		font-size: 0.9rem;
		margin-bottom: 0;
	}
	.empty {
		color: var(--muted);
		font-size: 0.9rem;
	}

	.project-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}
	.project-item {
		border-bottom: 1px solid var(--border);
		padding-bottom: 2.5rem;
	}
	.project-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}
	.project-link {
		display: block;
		text-decoration: none;
		color: var(--text);
	}
	.project-link:hover .project-title {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.project-link:hover .cover-img {
		opacity: 0.85;
	}

	.cover-wrap {
		width: 100%;
		margin-bottom: 1.1rem;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid var(--border);
		background: var(--surface);
	}
	.cover-img {
		width: 100%;
		height: auto;
		display: block;
		transition: opacity 0.2s;
	}

	.project-info {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.project-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}
	.project-title {
		font-size: 1rem;
		font-weight: 600;
	}
	.status {
		font-size: 0.7rem;
		padding: 0.15rem 0.5rem;
		border-radius: 3px;
		white-space: nowrap;
		flex-shrink: 0;
		font-weight: 500;
	}
	.status-active {
		background: rgba(74, 222, 128, 0.1);
		color: #4ade80;
		border: 1px solid rgba(74, 222, 128, 0.2);
	}
	.status-wip {
		background: rgba(251, 191, 36, 0.1);
		color: #fbbf24;
		border: 1px solid rgba(251, 191, 36, 0.2);
	}
	.status-archived {
		background: rgba(107, 107, 107, 0.1);
		color: var(--muted);
		border: 1px solid var(--border);
	}
	.project-desc {
		font-size: 0.875rem;
		color: var(--muted);
		line-height: 1.6;
		margin: 0;
	}
	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}
	.tech {
		font-size: 0.75rem;
		padding: 0.2rem 0.55rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--muted);
	}
</style>
