---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import lucasPhoto from '../assets/lucas-lima.jpg';
import { GITHUB_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-inner">
				<Image src={lucasPhoto} alt="Lucas Lima" width={140} height={140} class="avatar" />
				<div class="hero-text">
					<h1>Lucas Lima.</h1>
					<p class="role">Desenvolvedor de software transformador</p>
					<p class="bio">
						Apaixonado por resolver problemas difíceis e construir sistemas que funcionam de verdade
						em produção. Gosto de código limpo, arquitetura bem pensada e de aprender algo novo em
						cada desafio que aparece.
					</p>
					<nav class="ctas" aria-label="Navegação principal">
						<a href="/blog" class="cta">Posts</a>
						<a href="/projects" class="cta">Projetos</a>
						<a href="/about" class="cta">Sobre</a>
						<a href={GITHUB_URL} target="_blank" rel="noopener" class="cta cta-external">GitHub ↗</a>
					</nav>
				</div>
			</div>
			</section>

			{
				posts.length > 0 && (
					<section class="section">
						<h2 class="section-label">Posts recentes</h2>
						<ul class="post-list">
							{posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`} class="post-link">
										<span class="post-title">{post.data.title}</span>
										<span class="post-date">
											{post.data.pubDate.toLocaleDateString('pt-BR', {
												month: 'short',
												year: 'numeric',
											})}
										</span>
									</a>
									{post.data.description && (
										<p class="post-desc">{post.data.description}</p>
									)}
								</li>
							))}
						</ul>
						<a href="/blog" class="see-all">Ver todos os posts →</a>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 3rem;
	}
	.hero-inner {
		display: flex;
		align-items: flex-start;
		gap: 1.75rem;
	}
	.avatar {
		width: 140px;
		height: 140px;
		border-radius: 50%;
		object-fit: cover;
		object-position: center top;
		border: 2px solid var(--border);
		flex-shrink: 0;
	}
	.hero-text {
		flex: 1;
		min-width: 0;
	}
	h1 {
		font-size: 2.25rem;
		letter-spacing: -0.04em;
		margin: 0 0 0.3rem;
	}
	.role {
		color: var(--muted);
		font-size: 0.875rem;
		margin-bottom: 1.1rem;
	}
	.bio {
		line-height: 1.7;
		margin-bottom: 1.5rem;
		color: var(--text);
		font-size: 0.925rem;
	}
	.ctas {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	@media (max-width: 520px) {
		.hero-inner {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
		.ctas {
			justify-content: center;
		}
	}
	.cta {
		font-size: 0.825rem;
		text-decoration: none;
		padding: 0.4rem 0.9rem;
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--muted);
		background: var(--surface);
		transition: color 0.15s, border-color 0.15s;
	}
	.cta:hover {
		color: var(--text);
		border-color: var(--muted);
		text-decoration: none;
	}
	.cta-external {
		margin-left: 0.25rem;
	}

	.section {
		margin-bottom: 2.5rem;
	}
	.section-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--muted);
		font-weight: 600;
		margin-bottom: 1.25rem;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.post-link {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		text-decoration: none;
		color: var(--text);
	}
	.post-link:hover .post-title {
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.post-title {
		font-size: 0.9rem;
		font-weight: 500;
	}
	.post-date {
		font-size: 0.775rem;
		color: var(--muted);
		white-space: nowrap;
		flex-shrink: 0;
	}
	.post-desc {
		margin: 0.3rem 0 0;
		font-size: 0.825rem;
		color: var(--muted);
		line-height: 1.5;
	}
	.see-all {
		font-size: 0.825rem;
		color: var(--muted);
		text-decoration: none;
		transition: color 0.15s;
	}
	.see-all:hover {
		color: var(--text);
		text-decoration: none;
	}
</style>
