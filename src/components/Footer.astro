---
import { EMAIL, GITHUB_URL, LINKEDIN_URL } from '../consts';

const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<span class="copy">&copy; {year} Lucas Lima</span>
		<div class="links">
			<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
			<a href={LINKEDIN_URL} target="_blank" rel="noopener">LinkedIn</a>
			<a href={`mailto:${EMAIL}`}>Email</a>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		margin-top: 4rem;
	}
	.inner {
		max-width: 680px;
		margin: 0 auto;
		padding: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.copy {
		font-size: 0.8rem;
		color: var(--muted);
	}
	.links {
		display: flex;
		gap: 1.25rem;
	}
	.links a {
		font-size: 0.8rem;
		color: var(--muted);
		text-decoration: none;
		transition: color 0.15s;
	}
	.links a:hover {
		color: var(--text);
	}
	@media (max-width: 480px) {
		.inner {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75rem;
		}
	}
</style>
