---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
	day: '2-digit',
	month: 'long',
	year: 'numeric',
});
const formattedUpdated = updatedDate?.toLocaleDateString('pt-BR', {
	day: '2-digit',
	month: 'long',
	year: 'numeric',
});
---

<html lang="pt-BR">
	<head>
		<BaseHead title={`${title} — Lucas Lima`} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<header class="post-header">
					<div class="post-dates">
						<time datetime={pubDate.toISOString()}>{formattedDate}</time>
						{formattedUpdated && <span class="updated">Atualizado em {formattedUpdated}</span>}
					</div>
					<h1>{title}</h1>
					{description && <p class="post-desc">{description}</p>}
				</header>

				{
					heroImage && (
						<div class="hero-image">
							<Image width={680} height={360} src={heroImage} alt="" />
						</div>
					)
				}

				<div class="prose">
					<slot />
				</div>

				<footer class="post-footer">
					<a href="/blog" class="back-link">← Voltar ao blog</a>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-header {
		padding-bottom: 1.75rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2rem;
	}
	.post-dates {
		display: flex;
		gap: 1rem;
		align-items: center;
		flex-wrap: wrap;
		margin-bottom: 0.75rem;
	}
	time {
		font-size: 0.825rem;
		color: var(--muted);
	}
	.updated {
		font-size: 0.775rem;
		color: var(--dim);
		font-style: italic;
	}
	h1 {
		font-size: 1.875rem;
		letter-spacing: -0.03em;
		margin: 0 0 0.75rem;
		line-height: 1.2;
	}
	.post-desc {
		font-size: 1rem;
		color: var(--muted);
		margin: 0;
		line-height: 1.6;
	}

	.hero-image {
		margin-bottom: 2rem;
	}
	.hero-image img {
		width: 100%;
		border: 1px solid var(--border);
	}

	/* Prose */
	.prose {
		font-size: 1rem;
		line-height: 1.8;
	}
	.prose :global(h2) {
		font-size: 1.375rem;
		margin: 2.5rem 0 0.75rem;
		letter-spacing: -0.02em;
		text-transform: none;
		color: var(--text);
	}
	.prose :global(h3) {
		font-size: 1.1rem;
		margin: 1.75rem 0 0.5rem;
		letter-spacing: -0.01em;
		text-transform: none;
	}
	.prose :global(p) {
		margin-bottom: 1.25em;
	}
	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1.25em;
	}
	.prose :global(li) {
		margin-bottom: 0.4em;
	}
	.prose :global(a) {
		color: var(--text);
	}
	.prose :global(blockquote) {
		margin: 1.5em 0;
		padding: 0 0 0 1.25rem;
		border-left: 2px solid var(--dim);
		color: var(--muted);
		font-style: italic;
	}
	.prose :global(hr) {
		margin: 2rem 0;
	}

	/* Post footer */
	.post-footer {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
	}
	.back-link {
		font-size: 0.875rem;
		color: var(--muted);
		text-decoration: none;
		transition: color 0.15s;
	}
	.back-link:hover {
		color: var(--text);
		text-decoration: none;
	}
</style>
